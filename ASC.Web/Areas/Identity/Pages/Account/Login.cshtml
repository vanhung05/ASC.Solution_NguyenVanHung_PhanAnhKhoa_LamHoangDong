@page
@model LoginModel
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Log in";
}

<div class="container">
    <div class="row">
        <div class="col s12 m5 offset-m1">
            <form asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>

                @if (TempData["ExternalLoginError"] != null)
                {
                    <div class="card-panel red lighten-4 red-text text-darken-4">
                        @TempData["ExternalLoginError"]
                    </div>
                }

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="Input.Email" type="email" class="validate" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="Input.Password" type="password" class="validate" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                </div>

                <div class="row padding-left-10px">
                    <p>
                        <label>
                            <input asp-for="Input.RememberMe" type="checkbox" class="filled-in" />
                            <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                        </label>
                    </p>
                </div>

                <div class="row center">
                    <button class="btn waves-effect waves-light" type="submit">
                        Submit
                        <i class="material-icons right">send</i>
                    </button>
                </div>

                <div class="row center">
                    <a href="/Identity/Account/ForgotPassword">Forgot your password?</a>
                </div>
            </form>
        </div>

        <div class="col s12 m4">
            <div class="card-panel">
                <h5>Đăng nhập bằng Google</h5>
                <hr />

                @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <p class="grey-text">Chưa cấu hình đăng nhập ngoài.</p>
                }
                else
                {
                    <form id="external-account"
                          asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    class="btn red darken-1 waves-effect waves-light"
                                    style="width:100%; margin-top:10px;"
                                    name="provider"
                                    value="@provider.Name"
                                    title="Đăng nhập bằng @provider.DisplayName">
                                @provider.DisplayName
                            </button>
                        }
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}