@model ASC.Web.Areas.ServiceRequests.Models.NewServiceRequestViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "_SecureLayout";
}

<div class="row"></div>

<div class="row padding-top-20px padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="col s12 padding-20px">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>New Service Request</h5>
            </div>

            <div class="divider"></div>

            <form asp-controller="ServiceRequest"
                  asp-action="ServiceRequest"
                  asp-area="ServiceRequests"
                  method="post"
                  class="col s12">

                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="input-field col s4">
                        <select asp-for="VehicleName"
                                asp-items="@(new SelectList(ViewBag.VehicleNames, "Name", "Name"))"
                                required="required">
                            <option value="">Please select one</option>
                        </select>
                        <label asp-for="VehicleName"></label>
                        <span asp-validation-for="VehicleName" class="red-text"></span>
                    </div>

                    <div class="input-field col s4">
                        <select asp-for="VehicleType"
                                asp-items="@(new SelectList(ViewBag.VehicleTypes, "Name", "Name"))"
                                required="required">
                            <option value="">Please select one</option>
                        </select>
                        <label asp-for="VehicleType"></label>
                        <span asp-validation-for="VehicleType" class="red-text"></span>
                    </div>

                    <div class="input-field col s4">
                        <input id="RequestedDateDisplay" type="text" class="datepicker" />
                        <input asp-for="RequestedDate" type="hidden" id="RequestedDateHidden" />
                        <label for="RequestedDateDisplay">Requested Date</label>
                        <span asp-validation-for="RequestedDate" class="red-text"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s8">
                        <textarea asp-for="RequestedServices" class="materialize-textarea validate"></textarea>
                        <label asp-for="RequestedServices"></label>
                        <span asp-validation-for="RequestedServices" class="red-text"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12 right-align">
                        <button class="btn waves-effect waves-light btnSubmit" type="submit" name="action">
                            Create
                            <i class="material-icons right">send</i>
                        </button>
                    </div>

                    <div class="row col s12 right-align" asp-validation-summary="All"></div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.datepicker').datepicker({
                format: 'dd/mm/yyyy',
                onSelect: function(selectedDate) {
                    if (selectedDate) {
                        var year = selectedDate.getFullYear();
                        var month = ('0' + (selectedDate.getMonth() + 1)).slice(-2);
                        var day = ('0' + selectedDate.getDate()).slice(-2);
                        $('#RequestedDateHidden').val(year + '-' + month + '-' + day);
                    }
                }
            });

            $('select').formSelect();

            $("select[required]").css({
                display: "block",
                position: "absolute",
                visibility: "hidden"
            });
        });
    </script>
}